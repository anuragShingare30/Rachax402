RECIPIENT_ADDRESS= #SToracha Wallet Address
FACILITATOR_URL=https://x402.org/facilitator
PROVIDER_WALLET_ADDRESS= #AgentB Wallet Address
STORACHA_PROVIDER_PRIVATE_KEY= #Storacha Agent Wallet Private Key
PORT=8000 #Storacha Storage Service Port
PROVIDER_PORT=8001 #AgentB Data Analyzer Service Port

# CDP Production Facilitator (from https://portal.cdp.coinbase.com)
# When both are set, servers auto-switch to CDP facilitator + Base mainnet
# CDP_API_KEY_ID="your-cdp-api-key-id"
# CDP_API_KEY_SECRET="your-cdp-api-key-secret"

# Override network (CAIP-2): eip155:84532 (Base Sepolia) or eip155:8453 (Base mainnet)
# Auto-detected: testnet without CDP keys, mainnet with CDP keys
CDP_API_KEY_ID= #CDP API Key ID
CDP_API_KEY_SECRET= #CDP API Key Secret
X402_NETWORK= #CAIP-2 network (e.g. "eip155:84532" for Base Sepolia)
STORACHA_PVT_KEY= #Storacha Agent Wallet Private Key
STORACHA_DELEGATION_KEY= #Storacha Agent Wallet Delegation



# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Railway Deployment Guide — Rachax402 AgentB Services
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# STEP 1: Create Railway project
#   railway.app → New Project → Deploy from GitHub repo
#   Select: antiphon/server/ as root directory
#
# STEP 2: Create Service 1 — Data Analyzer
#   Add Service → GitHub → same repo → root = server/
#   Set env vars below under [DATA ANALYZER SERVICE]
#
# STEP 3: Create Service 2 — Storacha Storage
#   Add Service → GitHub → same repo → root = server/
#   Set env vars below under [STORACHA STORAGE SERVICE]
#
# STEP 4: After both deploy, run update-agent-cards.js with Railway URLs
#   ANALYZER_URL=https://analyzer-xyz.up.railway.app \
#   STORAGE_URL=https://storage-xyz.up.railway.app \
#   node update-agent-cards.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── [DATA ANALYZER SERVICE] ──────────────────────────────────────────
# Railway dashboard → Service 1 → Variables → Raw Editor → paste:
SERVICE_TYPE=analyzer
PROVIDER_PORT=8001
PROVIDER_WALLET_ADDRESS=0xEAB418143643557C74479d38E773A64E35B5f6c9
FACILITATOR_URL=https://x402.org/facilitator
BASE_RPC_URL=https://sepolia.base.org
# Storacha creds for AgentB to upload results after analysis:
STORACHA_AGENT_PRIVATE_KEY=<same key used in server/.env>
STORACHA_AGENT_DELEGATION=<same delegation used in server/.env>

# ── [STORACHA STORAGE SERVICE] ──────────────────────────────────────
# Railway dashboard → Service 2 → Variables → Raw Editor → paste:
SERVICE_TYPE=storage
PORT=8000
RECIPIENT_ADDRESS=0x9D48b65Bb45f144CBC5662Fd3Fd011659371D0f8
FACILITATOR_URL=https://x402.org/facilitator
BASE_RPC_URL=https://sepolia.base.org
STORACHA_AGENT_PRIVATE_KEY=<storacha provider private key>
STORACHA_AGENT_DELEGATION=<storacha provider delegation>

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HEALTH CHECK URLs (verify after deploy):
#   https://YOUR-ANALYZER.up.railway.app/health
#   https://YOUR-STORAGE.up.railway.app/health
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
